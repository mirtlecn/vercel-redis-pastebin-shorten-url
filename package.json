{
  "name": "post",
  "version": "1.4.1",
  "description": "A lightweight link shortener, pastebin and file sharing service",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "assets:update": "node scripts/update-embedded-assets.mjs",
    "build": "vite build",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "node server.js",
    "dev:web": "vite",
    "start": "npm run build && npm run start:server",
    "start:server": "node server.js",
    "test": "npm run test:unit && npm run test:smoke:web:local",
    "test:all": "npm run test:unit && npm run test:smoke:web:local && npm run test:smoke:api:local",
    "test:unit": "node --test",
    "version:bump": "node scripts/bump-version.mjs",
    "vercel": "vercel dev",
    "test:smoke:web:local": "bash test/functional/run-local.sh",
    "test:smoke:api:local": "bash test/functional/run-api-local.sh",
    "test:smoke:web:vercel": "bash test/functional/run-vercel.sh",
    "test:functional": "bash test/functional/test-functional.sh",
    "test:functional:local": "npm run test:smoke:web:local",
    "test:functional:api:local": "npm run test:smoke:api:local",
    "test:functional:vercel": "npm run test:smoke:web:vercel"
  },
  "keywords": [],
  "author": "Mirtle",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "formidable": "^3.5.4",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.3",
    "marked-alert": "^2.1.2",
    "marked-footnote": "^1.4.0",
    "marked-gfm-heading-id": "^4.1.3",
    "marked-highlight": "^2.2.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "redis": "^5.11.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
