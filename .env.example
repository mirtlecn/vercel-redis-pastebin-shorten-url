# Redis connection URL redis://default:password@host:port
# e.g. redis://localhost:6379/0
# For TLS/SSL, use rediss:// instead of redis://
LINKS_REDIS_URL=redis://user:password@host:port/db-number

# Secret key for API authentication
SECRET_KEY=your-secret-key-here

# Admin GUI password
ADMIN_KEY=your-admin-password-here

# Port | default is 3000
# LINKS_PORT=3000

# Max text size in KB | default is 500kb
# MAX_CONTENT_SIZE_KB=500

# S3 Configuration (for file uploads)
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=auto

# S3 max file upload size in MB | default is 10mb
# MAX_FILE_SIZE_MB=10
