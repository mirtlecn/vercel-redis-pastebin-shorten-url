# Redis connection URL e.g. redis://localhost:6379
LINKS_REDIS_URL=redis://default:password@host:port

# Secret key for API authentication
SECRET_KEY=your-secret-key-here

# Admin GUI password
ADMIN_KEY=your-admin-password-here

# Port
# LINKS_PORT=3000

# Max text size in KB
# MAX_CONTENT_SIZE_KB=500

# S3/R2 Configuration (for file uploads)
# S3_ENDPOINT=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_BUCKET_NAME=
# S3_REGION=auto

# Max file upload size in MB
# MAX_FILE_SIZE_MB=10
