{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin/index.html"
    },
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/:path((?!admin(?:/|$)|api(?:/|$)|_vercel(?:/|$)).*)",
      "destination": "/api/:path*"
    }
  ]
}
